# ---------------------------------------------------------------------------
# .gitignore — openclaw-audit
# ---------------------------------------------------------------------------

# Scan output (generated by every run of `openclaw-audit scan`)
scan_output/

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# Tool caches
.mypy_cache/
.ruff_cache/
.pytest_cache/

# OS files
Thumbs.db
.DS_Store
